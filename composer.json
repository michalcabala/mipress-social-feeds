{
    "name": "mipress/social-feeds",
    "description": "Social feeds integration for miPress CMS",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0",
        "filament/filament": "^5.0",
        "laravel/socialite": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "MiPress\\SocialFeeds\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MiPress\\SocialFeeds\\SocialFeedsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
